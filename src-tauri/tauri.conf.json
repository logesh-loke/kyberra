{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Crypsyn",
  "version": "0.1.0",
  "identifier": "com.crypsyn.dev",
  "build": {
    "devUrl": "https://crypsyn.com"
  },
  "app": {
    "windows": [
      {
        "title": "Crypsyn",
        "width": 1000,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "https://crypsyn.com"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
